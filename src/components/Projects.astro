---
interface Project {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  tags: string[];
  icon: string;
  color: string;
  features: string[];
  status: 'Active' | 'Completed';
  statusNote: string;
}

const projects: Project[] = [
  {
    id: 'foxtunes',
    title: 'FoxTunes',
    subtitle: 'Discord Music Bot',
    description:
      'A fully-featured Discord music bot designed for reliability and effortless control across large communities. Currently live on 37 servers and actively maintained.',
    tags: ['TypeScript', 'Node.js', 'Discord.js', 'Lavalink'],
    icon: '🦊',
    color: '#f97316',
    status: 'Active',
    statusNote: 'Actively updated · 37 servers',
    features: [
      'Playback from YouTube, Spotify and SoundCloud',
      'Queue management and playlists',
      'Slash commands & context menus',
      'Low latency audio via Lavalink',
      'Per-server persistent settings',
    ],
  },
  {
    id: 'anticheat',
    title: "Erik's Anti-Cheat",
    subtitle: 'Minecraft Server Anti-Cheat',
    description:
      'A simple anti-cheat system for Minecraft servers connected through a client-side mod — detecting cheats directly from the client.',
    tags: ['Java', 'Spigot API', 'Fabric API', 'MySQL'],
    icon: '🛡️',
    color: '#8b5cf6',
    status: 'Completed',
    statusNote: 'Completed & deployed',
    features: [
      'Detects cheats client-side',
      'Automatically blocks server connection',
    ],
  },
];
---

<section class="section" id="projects">
  <div class="glow-divider"></div>

  <div class="container">
    <p class="section-label">Projects</p>
    <h2 class="section-heading">
      Things I've<br/>
      <span>built.</span>
    </h2>
    <p class="projects__intro">
      These are projects I've worked on
    </p>

    <div class="projects__list">
      {projects.map((project, i) => (
        <article class="project-card" style={`--accent: ${project.color}`}>
          <div class="project-card__glow"></div>

          <div class="project-card__header">
            <div class="project-card__icon-wrap">
              <span class="project-card__emoji">{project.icon}</span>
            </div>
            <div class="project-card__meta">
              <span class="project-card__num">0{i + 1}</span>
              <span class={`project-card__status status--${project.status === 'Active' ? 'active' : 'done'}`}>
                {project.status}
              </span>
            </div>
          </div>

          <div class="project-card__body">
            <h3 class="project-card__title">{project.title}</h3>
            <p class="project-card__subtitle">{project.subtitle}</p>
            <p class="project-card__status-note">{project.statusNote}</p>
            <p class="project-card__desc">{project.description}</p>
          </div>

          <div class="project-card__features">
            <p class="project-card__features-label">Key features</p>
            <ul>
              {project.features.map(f => (
                <li>
                  <span class="bullet">▸</span>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          <div class="project-card__footer">
            <div class="project-card__tags">
              {project.tags.map(tag => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.projects__intro {
  font-size: 1.05rem;
  color: rgba(232, 213, 255, 0.55);
  max-width: 560px;
  margin-bottom: 4rem;
  line-height: 1.85;
}

.projects__list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(460px, 1fr));
  gap: 1.5rem;
}

.project-card {
  position: relative;
  background: rgba(13, 8, 36, 0.6);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2.25rem;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
  transition: border-color 0.3s ease, transform 0.3s ease;
}

.project-card:hover {
  border-color: var(--border-bright);
  transform: translateY(-4px);
}

.project-card__glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0.7;
  transition: opacity 0.3s ease;
}

.project-card:hover .project-card__glow {
  opacity: 1;
}

.project-card__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.project-card__icon-wrap {
  width: 56px;
  height: 56px;
  background: rgba(42, 21, 88, 0.6);
  border: 1px solid var(--border);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.75rem;
}

.project-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.5rem;
}

.project-card__num {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: rgba(196, 157, 245, 0.3);
  letter-spacing: 0.1em;
}

.project-card__status {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.3rem 0.7rem;
  border-radius: 20px;
}

.status--active {
  background: rgba(74, 222, 128, 0.1);
  border: 1px solid rgba(74, 222, 128, 0.3);
  color: #4ade80;
}

.status--done {
  background: rgba(168, 85, 247, 0.1);
  border: 1px solid rgba(168, 85, 247, 0.3);
  color: var(--amethyst);
}

.project-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.project-card__title {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--starlight);
  letter-spacing: -0.02em;
}

.project-card__subtitle {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--amethyst);
}

.project-card__status-note {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: rgba(196, 157, 245, 0.4);
  letter-spacing: 0.05em;
  margin-top: 0.1rem;
}

.project-card__desc {
  font-size: 1rem;
  color: rgba(232, 213, 255, 0.6);
  line-height: 1.75;
  margin-top: 0.4rem;
}

.project-card__features {
  background: rgba(8, 4, 24, 0.5);
  border: 1px solid rgba(107, 63, 160, 0.2);
  border-radius: 10px;
  padding: 1.25rem 1.5rem;
}

.project-card__features-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--amethyst);
  margin-bottom: 0.75rem;
}

.project-card__features ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.project-card__features li {
  font-size: 0.95rem;
  color: rgba(232, 213, 255, 0.6);
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  line-height: 1.5;
}

.bullet {
  color: var(--amethyst);
  flex-shrink: 0;
  font-size: 0.7rem;
  margin-top: 0.25rem;
}

.project-card__footer {
  margin-top: auto;
}

.project-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.project-tag {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.08em;
  background: rgba(107, 63, 160, 0.15);
  border: 1px solid rgba(107, 63, 160, 0.3);
  color: var(--lavender);
  padding: 0.25rem 0.65rem;
  border-radius: 4px;
}

@media (max-width: 600px) {
  .projects__list {
    grid-template-columns: 1fr;
  }
}
</style>