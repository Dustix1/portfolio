---
---

<section class="section" id="about">
  <div class="glow-divider"></div>

  <div class="container about__grid">
    <div class="about__text">
      <p class="section-label">About me</p>
      <h2 class="section-heading">
        Who I am<br/>
        <span>and what I build.</span>
      </h2>

      <div class="about__bio">
        <p>
          I'm a computer science student with a strong passion for software development.
          I enjoy building tools that solve real problems — from Discord bots powering
          communities to security systems for game servers.
        </p>
        <p>
          My work is grounded in solid fundamentals: clean code, good architecture, and
          technology chosen with purpose. I'm curious by nature and never stop digging
          until I fully understand something.
        </p>
        <p>
          Outside of coding I'm interested in cybersecurity, space, and building things
          that look simple on the surface but are genuinely complex underneath.
        </p>
      </div>

      <div class="about__facts">
        <div class="about__fact">
          <span class="about__fact-num">05+</span>
          <span class="about__fact-label">Projects shipped</span>
        </div>
        <div class="about__fact">
          <span class="about__fact-num">∞ ☕</span>
          <span class="about__fact-label">Coffees consumed</span>
        </div>
      </div>
    </div>

    <div class="about__visual">
      <div class="about__card">
        <div class="about__card-glow"></div>

        <div class="about__avatar">
          <div class="about__avatar-ring"></div>
          <div class="about__avatar-inner">
            <img src="https://github.com/Dustix1.png" alt="David Kanovský" class="about__avatar-img">
          </div>
        </div>

        <div class="about__card-info">
          <h3 class="about__card-name">David Kanovský</h3>
          <br>
          <p class="about__card-role">Developer & Student</p>
        </div>

        <div class="about__card-tags">
          <span class="tag">TypeScript</span>
          <span class="tag">Java</span>
          <span class="tag">C#</span>
          <span class="tag">Discord.js</span>
          <span class="tag">Docker</span>
        </div>

        
      </div>
    </div>
  </div>
</section>

<style>
.about__grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 5rem;
  align-items: center;
}

.about__bio {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 3rem;
  color: rgba(232, 213, 255, 0.65);
  font-size: 1.05rem;
  line-height: 1.85;
}

.about__facts {
  display: flex;
  gap: 2.5rem;
}

.about__fact {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.about__fact-num {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--amethyst), var(--nova));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.about__fact-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(196, 157, 245, 0.4);
}

.about__card {
  position: relative;
  background: rgba(13, 8, 36, 0.7);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2.5rem 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
  overflow: hidden;
  backdrop-filter: blur(10px);
}

.about__card-glow {
  position: absolute;
  top: -50%;
  left: 50%;
  transform: translateX(-50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(ellipse at center top, rgba(107,63,160,0.15) 0%, transparent 50%);
  pointer-events: none;
}

.about__avatar {
  position: relative;
  width: 100px;
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.about__avatar-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2px solid transparent;
  background: linear-gradient(135deg, var(--violet), var(--nova)) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
  mask-composite: exclude;
  animation: ringRotate 8s linear infinite;
}

@keyframes ringRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.about__avatar-inner {
  width: 84px;
  height: 84px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--cosmic) 0%, var(--abyss) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.about__avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.about__card-name {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--starlight);
  letter-spacing: -0.02em;
  text-align: center;
}

.about__card-role {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--amethyst);
  text-align: center;
  margin-top: -1rem;
}

.about__card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
}

.tag {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  background: rgba(107, 63, 160, 0.2);
  border: 1px solid rgba(107, 63, 160, 0.4);
  color: var(--lavender);
  padding: 0.3rem 0.7rem;
  border-radius: 20px;
}

.about__card-status {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  color: rgba(196, 157, 245, 0.5);
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 8px #4ade80;
  animation: blink 2s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

@media (max-width: 900px) {
  .about__grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .about__visual {
    max-width: 360px;
    margin: 0 auto;
    width: 100%;
  }
}

@media (max-width: 500px) {
  .about__facts {
    gap: 1.5rem;
    flex-wrap: wrap;
  }
}
</style>