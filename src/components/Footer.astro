---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="glow-divider"></div>
  <div class="footer__inner">
    <p class="footer__brand">
      <span class="bracket">[</span>dustix<span class="bracket">]</span>
    </p>
    <p class="footer__copy">
      &copy; {year} David Kanovský — Built with <span class="heart">♥</span> and Astro
    </p>
    <p class="footer__sub">
      Designed in the darkness of space.
    </p>
  </div>
</footer>

<style>
.footer {
  position: relative;
  z-index: 1;
  padding: 3rem 0 2.5rem;
}

.footer__inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 2rem 2rem 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  text-align: center;
}

.footer__brand {
  font-family: var(--font-mono);
  font-size: 1rem;
  color: var(--starlight);
  letter-spacing: 0.05em;
  margin-bottom: 0.5rem;
}

.bracket {
  color: var(--amethyst);
}

.footer__copy {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  color: rgba(196, 157, 245, 0.35);
}

.heart {
  color: var(--amethyst);
}

.footer__sub {
  font-style: italic;
  font-size: 0.85rem;
  color: rgba(196, 157, 245, 0.2);
}
</style>
