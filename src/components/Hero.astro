---
---

<section class="hero" id="hero">
  <!-- Interactive star canvas -->
  <canvas id="starCanvas" class="star-canvas"></canvas>

  <!-- Floating orbs -->
  <div class="orb orb--1"></div>
  <div class="orb orb--2"></div>
  <div class="orb orb--3"></div>

  <div class="hero__inner">
    <div class="hero__content">
      <p class="hero__greeting fade-in" style="animation-delay: 0.1s">
        <span class="hero__greeting-line"></span>
        Hello, my name is
      </p>
      <h1 class="hero__name fade-in" style="animation-delay: 0.2s">
        David Kanovský
      </h1>
      <h2 class="hero__tagline fade-in" style="animation-delay: 0.35s">
        I build things<br/>
        <span class="hero__tagline-accent">with logic and code.</span>
      </h2>
      <p class="hero__description fade-in" style="animation-delay: 0.5s">
        Developer with a passion for solving problems others consider impossible.
      </p>
      <div class="hero__actions fade-in" style="animation-delay: 0.65s">
        <a href="#projects" class="btn btn--primary">My projects</a>
        <a href="#contact" class="btn btn--ghost">Get in touch</a>
      </div>

      <div class="hero__scroll fade-in" style="animation-delay: 0.9s">
        <span class="hero__scroll-text">Scroll down</span>
        <div class="hero__scroll-line"></div>
      </div>
    </div>

    <div class="hero__system-wrap" aria-hidden="true">
      <!-- Central Sun -->
      <div class="hero__sun"></div>

      <!-- Hourglass Twins Orbit -->
      <div class="orbit-path orbit-path--1"></div>
      <div class="orbit-wrap orbit-wrap--1">
        <div class="orbit-inner-rotate" style="animation-delay: -2s;">
          <div class="planet-hourglass">
            <div class="planet-hourglass__ash"></div>
            <div class="planet-hourglass__ember"></div>
          </div>
        </div>
      </div>

      <!-- Timber Hearth Orbit -->
      <div class="orbit-path orbit-path--2"></div>
      <div class="orbit-wrap orbit-wrap--2">
        <div class="orbit-inner-rotate" style="animation-delay: -57s;">
          <div class="planet-timber">
            <div class="planet-timber__attlerock"></div>
          </div>
        </div>
      </div>

      <!-- Brittle Hollow Orbit -->
      <div class="orbit-path orbit-path--3"></div>
      <div class="orbit-wrap orbit-wrap--3">
        <div class="orbit-inner-rotate" style="animation-delay: -12s;">
          <div class="planet-brittle">
            <div class="planet-brittle__lantern"></div>
          </div>
        </div>
      </div>

      <!-- Giant's Deep Orbit -->
      <div class="orbit-path orbit-path--4"></div>
      <div class="orbit-wrap orbit-wrap--4">
        <div class="orbit-inner-rotate" style="animation-delay: -40s;">
          <div class="planet-giants"></div>
        </div>
      </div>

      <!-- Dark Bramble Orbit -->
      <div class="orbit-path orbit-path--5"></div>
      <div class="orbit-wrap orbit-wrap--5">
        <div class="orbit-inner-rotate" style="animation-delay: -45s;">
          <div class="planet-bramble"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  min-height: 100svh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  z-index: 1;
  padding-top: 80px;
}

.star-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
}

.orb--1 {
  width: 500px;
  height: 500px;
  left: -100px;
  bottom: -100px;
  background: radial-gradient(circle, rgba(107,63,160,0.2) 0%, transparent 60%);
  animation: orbFloat 10s ease-in-out infinite alternate;
}

.orb--2 {
  width: 350px;
  height: 350px;
  right: 10%;
  top: 20%;
  background: radial-gradient(circle, rgba(168,85,247,0.12) 0%, transparent 60%);
  animation: orbFloat 13s ease-in-out infinite alternate-reverse;
}

.orb--3 {
  width: 250px;
  height: 250px;
  left: 40%;
  top: 10%;
  background: radial-gradient(circle, rgba(124,58,237,0.1) 0%, transparent 60%);
  animation: orbFloat 7s ease-in-out infinite alternate;
}

@keyframes orbFloat {
  0% { transform: translate(0, 0) scale(1); }
  100% { transform: translate(20px, -30px) scale(1.05); }
}

.hero__inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  width: 100%;
  position: relative;
  z-index: 2;
}

.hero__content {
  position: relative;
}

.hero__greeting {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  color: var(--amethyst);
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
  opacity: 0;
}

.hero__greeting-line {
  display: block;
  width: 2.5rem;
  height: 1px;
  background: var(--amethyst);
}

.hero__name {
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 800;
  color: var(--starlight);
  line-height: 1;
  margin-bottom: 0.75rem;
  letter-spacing: -0.03em;
  opacity: 0;
}

.hero__tagline {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 3vw, 2.2rem);
  font-weight: 600;
  color: rgba(232, 213, 255, 0.5);
  line-height: 1.2;
  margin-bottom: 1.75rem;
  opacity: 0;
}

.hero__tagline-accent {
  background: linear-gradient(135deg, var(--amethyst) 0%, var(--nova) 60%, var(--shimmer) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero__description {
  font-size: 1.1rem;
  color: rgba(232, 213, 255, 0.55);
  line-height: 1.8;
  max-width: 480px;
  margin-bottom: 2.5rem;
  opacity: 0;
}

.hero__actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  opacity: 0;
}

.btn {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.85rem 2rem;
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.25s ease;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.btn--primary {
  background: linear-gradient(135deg, var(--pulse) 0%, var(--violet) 100%);
  color: white;
  border: 1px solid rgba(168, 85, 247, 0.4);
  box-shadow: 0 0 20px rgba(124, 58, 237, 0.3), inset 0 1px 0 rgba(255,255,255,0.1);
}

.btn--primary:hover {
  background: linear-gradient(135deg, var(--glow) 0%, var(--pulse) 100%);
  box-shadow: 0 0 35px rgba(168, 85, 247, 0.5);
  color: white;
  transform: translateY(-2px);
}

.btn--ghost {
  background: transparent;
  color: var(--lavender);
  border: 1px solid var(--border-bright);
}

.btn--ghost:hover {
  background: rgba(107, 63, 160, 0.15);
  color: var(--shimmer);
  border-color: var(--amethyst);
}

.hero__scroll {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-top: 3.5rem;
  opacity: 0;
}

.hero__scroll-text {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(196, 157, 245, 0.4);
}

.hero__scroll-line {
  width: 40px;
  height: 1px;
  background: linear-gradient(90deg, rgba(196, 157, 245, 0.4), transparent);
  position: relative;
  overflow: hidden;
}

.hero__scroll-line::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: var(--amethyst);
  animation: scanLine 2s ease-in-out infinite;
}

@keyframes scanLine {
  0% { left: -100%; }
  100% { left: 200%; }
}

/* ===== Outer Wilds Solar System ===== */
.hero__system-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 480px;
  height: 480px;
  justify-self: center;
  background: radial-gradient(circle at center, rgba(4, 2, 13, 0.8) 0%, transparent 70%);
  border-radius: 50%;
}

.hero__sun {
  width: 60px;
  height: 60px;
  background: radial-gradient(circle at center, #fff 0%, #ffcc00 30%, #ff6600 70%, transparent 100%);
  border-radius: 50%;
  box-shadow: 0 0 40px #ff6600, 0 0 80px rgba(255, 102, 0, 0.4);
  position: relative;
  z-index: 10;
  animation: sunPulse 4s ease-in-out infinite alternate;
}

@keyframes sunPulse {
  from { transform: scale(1); filter: brightness(1); }
  to { transform: scale(1.05); filter: brightness(1.2); }
}

.orbit-path {
  position: absolute;
  border: 1px solid rgba(196, 157, 245, 0.1);
  border-radius: 50%;
  pointer-events: none;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.orbit-wrap {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.orbit-inner-rotate {
  width: 100%;
  height: 100%;
  animation: rotate linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* Hourglass Twins */
.orbit-path--1, .orbit-wrap--1 { width: 140px; height: 140px; }
.orbit-wrap--1 .orbit-inner-rotate { 
  animation-duration: 10s; 
  animation-delay: -2.5s;
}
.planet-hourglass {
  position: absolute;
  top: 0;
  left: 50%;
  width: 30px;
  height: 30px;
  transform: translate(-50%, -50%);
  animation: rotate 4s linear infinite;
}
.planet-hourglass__ash, .planet-hourglass__ember {
  position: absolute;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  left: 50%;
  margin-left: -4px;
}
.planet-hourglass__ash { background: #999; top: 0; }
.planet-hourglass__ember { background: #d2a679; bottom: 0; }

/* Timber Hearth */
.orbit-path--2, .orbit-wrap--2 { width: 220px; height: 220px; }
.orbit-wrap--2 .orbit-inner-rotate { 
  animation-duration: 20s; 
  animation-delay: -5s;
}
.planet-timber {
  position: absolute;
  top: 0;
  left: 50%;
  width: 14px;
  height: 14px;
  background: #4a6baf;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: inset -2px -2px 4px rgba(0,0,0,0.5);
}
.planet-timber__attlerock {
  position: absolute;
  width: 4px;
  height: 4px;
  background: #bbb;
  border-radius: 50%;
  top: -8px;
  left: 50%;
  transform: translateX(-50%);
  animation: rotate 5s linear infinite;
  transform-origin: 50% 15px;
}

/* Brittle Hollow */
.orbit-path--3, .orbit-wrap--3 { width: 300px; height: 300px; }
.orbit-wrap--3 .orbit-inner-rotate { 
  animation-duration: 35s; 
  animation-delay: -12s;
}
.planet-brittle {
  position: absolute;
  top: 0;
  left: 50%;
  width: 16px;
  height: 16px;
  background: #3d2b56;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}
.planet-brittle::after {
  content: '';
  position: absolute;
  inset: 3px;
  background: #111;
  border-radius: 50%;
}
.planet-brittle__lantern {
  position: absolute;
  width: 5px;
  height: 5px;
  background: #ff4400;
  border-radius: 50%;
  top: -10px;
  left: 50%;
  transform: translateX(-50%);
  box-shadow: 0 0 5px #ff4400;
  animation: rotate 8s linear infinite;
  transform-origin: 50% 18px;
}

/* Giant's Deep */
.orbit-path--4, .orbit-wrap--4 { width: 390px; height: 390px; }
.orbit-wrap--4 .orbit-inner-rotate { 
  animation-duration: 55s; 
  animation-delay: -25s;
}
.planet-giants {
  position: absolute;
  top: 0;
  left: 50%;
  width: 26px;
  height: 26px;
  background: radial-gradient(circle at 30% 30%, #2e8b57, #1a472a);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 15px rgba(46, 139, 87, 0.4);
}

/* Dark Bramble */
.orbit-path--5, .orbit-wrap--5 { width: 480px; height: 480px; }
.orbit-wrap--5 .orbit-inner-rotate { 
  animation-duration: 90s; 
  animation-delay: -45s;
}
.planet-bramble {
  position: absolute;
  top: 0;
  left: 50%;
  width: 12px;
  height: 12px;
  background: #2b2b2b;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  border: 1px solid #444;
}

@media (max-width: 900px) {
  .hero__inner {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .hero__system-wrap {
    width: 320px;
    height: 320px;
    margin-top: 2rem;
  }
  .orbit-path--1, .orbit-wrap--1 { width: 100px; height: 100px; }
  .orbit-path--2, .orbit-wrap--2 { width: 150px; height: 150px; }
  .orbit-path--3, .orbit-wrap--3 { width: 200px; height: 200px; }
  .orbit-path--4, .orbit-wrap--4 { width: 260px; height: 260px; }
  .orbit-path--5, .orbit-wrap--5 { width: 320px; height: 320px; }
}

@media (max-width: 500px) {
  .hero__system-wrap { display: none; }
}
</style>

<script>
  // ===== Interactive Star Field =====
  const canvas = document.getElementById('starCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let mouse = { x: -9999, y: -9999 };
  let width = 0;
  let height = 0;

  interface StarParticle {
    dx: number;
    dy: number;
    vx: number;
    vy: number;
    size: number;
    opacity: number;
  }

  interface Star {
    x: number;
    y: number;
    ox: number;
    oy: number;
    size: number;
    opacity: number;
    twinkleSpeed: number;
    twinkleOffset: number;
    color: string;
    isSupernova?: boolean;
    supernovaProgress?: number;
    supernovaSpeed?: number;
    particles?: StarParticle[];
  }

  const COLORS = ['rgba(255,255,255,', 'rgba(196,157,245,', 'rgba(168,85,247,', 'rgba(232,213,255,'];
  let stars: Star[] = [];
  const MOUSE_RADIUS = 80;
  const PUSH_STRENGTH = 12;
  const VOID_RADIUS = 260; // Area to keep clear of stars around the sun

  let sunPos = { x: 0, y: 0 };
  const sunEl = document.querySelector('.hero__sun');

  function updateSunPos() {
    if (sunEl) {
      const rect = sunEl.getBoundingClientRect();
      const canvasRect = canvas.getBoundingClientRect();
      sunPos.x = rect.left + rect.width / 2 - canvasRect.left;
      sunPos.y = rect.top + rect.height / 2 - canvasRect.top;
    }
  }

  function resize() {
    const hero = canvas.parentElement!;
    width = hero.offsetWidth;
    height = hero.offsetHeight;
    canvas.width = width;
    canvas.height = height;
    updateSunPos();
    initStars();
  }

  function initStars() {
    stars = [];
    const count = Math.floor((width * height) / 5000);
    for (let i = 0; i < count; i++) {
      const x = Math.random() * width;
      const y = Math.random() * height;
      
      const sdx = sunPos.x - x;
      const sdy = sunPos.y - y;
      const dist = Math.sqrt(sdx * sdx + sdy * sdy);
      
      if (dist < VOID_RADIUS) continue;

      stars.push({
        x, y, ox: x, oy: y,
        size: Math.random() * 1.8 + 0.3,
        opacity: Math.random() * 0.6 + 0.2,
        twinkleSpeed: Math.random() * 0.02 + 0.005,
        twinkleOffset: Math.random() * Math.PI * 2,
        color: COLORS[Math.floor(Math.random() * COLORS.length)],
        isSupernova: false,
        supernovaProgress: 0,
        supernovaSpeed: 1 / (300 + Math.random() * 100), // Dissolves for ~5-7 seconds
      });
    }
  }

  let frame = 0;
  let lastSupernovaTime = 0;

  function animate(time = 0) {
    requestAnimationFrame(animate);
    ctx.clearRect(0, 0, width, height);
    frame++;

    if (frame % 60 === 0) updateSunPos();

    // Trigger supernova - more frequent events (up to 7 seconds)
    if (stars.length > 0 && time - lastSupernovaTime > 1500 + Math.random() * 5500) {
      const availableStars = stars.filter(s => !s.isSupernova);
      if (availableStars.length > 0) {
        const star = availableStars[Math.floor(Math.random() * availableStars.length)];
        star.isSupernova = true;
        star.supernovaProgress = 0;
        star.particles = [];
        // More and smaller particles
        const particleCount = 20 + Math.floor(Math.random() * 15);
        for (let j = 0; j < particleCount; j++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = Math.random() * 0.6 + 0.2; // Slower particles
          star.particles.push({
            dx: 0, dy: 0,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            size: star.size * (Math.random() * 0.3 + 0.1), // Smaller particles
            opacity: 1
          });
        }
        lastSupernovaTime = time;
      }
    }

    for (let i = stars.length - 1; i >= 0; i--) {
      const star = stars[i];
      let twinkle = star.opacity + Math.sin(frame * star.twinkleSpeed + star.twinkleOffset) * 0.2;
      let tx = star.ox;
      let ty = star.oy;
      let size = star.size;
      let color = star.color;

      if (star.isSupernova) {
        star.supernovaProgress! += star.supernovaSpeed!;
        
        if (star.supernovaProgress! < 0.3) {
          // Phase 1: Brighten and Blue-shift (Swell)
          const p = star.supernovaProgress! / 0.3;
          size = star.size * (1 + p * 1.5);
          twinkle = star.opacity + p * (1 - star.opacity);
          color = 'rgba(200, 220, 255, ';
        } else {
          // Phase 2: Particle Burst
          const p = (star.supernovaProgress! - 0.3) / 0.7;
          
          for (const p_ of star.particles!) {
            p_.dx += p_.vx;
            p_.dy += p_.vy;
            p_.vx *= 0.99; // Very slow deceleration
            p_.vy *= 0.99;
            p_.opacity = 1 - p;
            
            ctx.beginPath();
            ctx.arc(star.x + p_.dx, star.y + p_.dy, p_.size, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(255, 255, 255, ' + (p_.opacity * (Math.random() * 0.4 + 0.6)) + ')';
            ctx.fill();
          }
          
          twinkle = 1 - p;
          size = star.size * (1 + 1.5) * (1 - p);
          color = 'rgba(255, 255, 255, ';
        }

        if (star.supernovaProgress! >= 1) {
          stars.splice(i, 1);
          continue;
        }
      } else {
        const mdx = tx - mouse.x;
        const mdy = ty - mouse.y;
        const mdist = Math.sqrt(mdx * mdx + mdy * mdy);

        if (mdist < MOUSE_RADIUS) {
          const force = (1 - mdist / MOUSE_RADIUS) * PUSH_STRENGTH;
          const angle = Math.atan2(mdy, mdx);
          tx += Math.cos(angle) * force;
          ty += Math.sin(angle) * force;
        }

        star.x += (tx - star.x) * 0.08;
        star.y += (ty - star.y) * 0.08;
      }

      if (!star.isSupernova || star.supernovaProgress! < 1) {
        ctx.beginPath();
        ctx.arc(star.x, star.y, size, 0, Math.PI * 2);
        ctx.fillStyle = color + Math.max(0, Math.min(1, twinkle)) + ')';
        ctx.fill();
      }
    }
  }

  window.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });

  window.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

  window.addEventListener('resize', resize);
  resize();
  animate();
</script>
